# Azure OpenAI Configuration
# Copy this file to .env and fill in the values.
# Do not commit the actual .env file to Git.

VITE_AZURE_OPENAI_ENDPOINT=https://your-endpoint.openai.azure.com
VITE_AZURE_OPENAI_API_KEY=your_api_key_here
VITE_AZURE_OPENAI_DEPLOYMENT=gpt-5.4
VITE_AZURE_OPENAI_DEPLOYMENT_MINI=gpt-5.4-mini
VITE_AZURE_OPENAI_EMBEDDING=text-embedding-3-large
VITE_AZURE_OPENAI_API_VERSION=2024-10-21
